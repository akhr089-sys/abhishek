<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>For Guddu 💕</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #ffe4f0, #f8d7f0, #ffe4f0);
      font-family: 'Segoe UI', sans-serif;
    }
    .heart { animation: float 3s ease-in-out infinite; }
    @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }
    .text-box {
      background-color: #ffe4f0 !important;
      border-radius: 20px;
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

  <!-- Starting Page -->
  <div id="startPage" class="max-w-xl w-full bg-white/95 rounded-3xl shadow-2xl overflow-hidden text-center p-10">
    <div class="mb-8">
      <div class="text-8xl heart mb-4">💖</div>
      <h1 class="text-4xl font-bold text-pink-600">For Guddu 💕</h1>
      <p class="mt-3 text-lg text-gray-600">My favourite person in this world</p>
    </div>

    <h2 class="text-3xl font-medium text-purple-700 mb-8">
      A Little Journey Just For You 💖
    </h2>

    <img src="https://media.giphy.com/media/3o7TKsQ3f9f3f3f3f3/giphy.gif" 
         class="mx-auto mb-10 w-60 h-60 object-contain rounded-3xl" alt="Cute Cat">

    <button onclick="startJourney()" 
      class="w-full py-6 text-2xl font-bold bg-gradient-to-r from-pink-500 to-purple-500 text-white rounded-3xl shadow-lg hover:scale-105 transition-transform">
      Start the Journey 💕
    </button>
  </div>

  <!-- Journey Page -->
  <div id="journeyPage" class="max-w-xl w-full bg-white/95 rounded-3xl shadow-2xl overflow-hidden hidden">

    <!-- Header -->
    <div class="bg-gradient-to-r from-pink-400 to-purple-500 text-white p-8 text-center">
      <h1 class="text-4xl font-bold">For Guddu 💕</h1>
      <h2 class="text-xl mt-2">A Little Journey Just For You</h2>
    </div>

    <!-- Music -->
    <div class="px-6 py-3 bg-pink-50 flex items-center gap-3 text-sm border-b">
      <i class="fa-solid fa-music text-pink-500"></i>
      <span class="font-medium text-pink-700">Now Playing: Sailor Song - Gigi Perez</span>
      <audio id="song" loop class="hidden">
        <!-- Gigi Perez - Sailor Song (Direct Audio Source) -->
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-18.mp3" type="audio/mpeg"> 
      </audio>
      <button onclick="toggleMusic()" class="ml-auto text-pink-500 hover:text-pink-600">
        <i id="playIcon" class="fa-solid fa-play"></i>
      </button>
    </div>

    <!-- Step Content -->
    <div id="stepContainer" class="p-8 min-h-[420px] text-center"></div>

    <!-- Progress -->
    <div class="px-8 pb-6">
      <div class="flex justify-between text-xs text-pink-600 mb-2">
        <span>Step <span id="currentStep">1</span> of 5</span>
      </div>
      <div class="h-2 bg-pink-100 rounded-full overflow-hidden">
        <div id="progressBar" class="h-2 bg-pink-500 w-1/5 transition-all"></div>
      </div>
    </div>

    <!-- Buttons -->
    <div class="flex px-8 pb-8 gap-4">
      <button onclick="prevStep()" id="prevBtn" class="flex-1 py-4 rounded-2xl border-2 border-pink-300 text-pink-600 font-medium hover:bg-pink-50">← Previous</button>
      <button onclick="nextStep()" id="nextBtn" class="flex-1 py-4 rounded-2xl bg-gradient-to-r from-pink-500 to-purple-500 text-white font-medium">Next →</button>
    </div>
  </div>

  <script>
    let currentStep = 1;
    const totalSteps = 5;

    const catGifs = [
      "https://media.giphy.com/media/3o7TKsQ3f9f3f3f3f3/giphy.gif",
      "https://media.giphy.com/media/JIX9t2j0ZTN9S/giphy.gif",
      "https://media.giphy.com/media/l0MYt5jPR6QX5pnqM/giphy.gif",
      "https://media.giphy.com/media/26ufnwz3wDUli7GU0/giphy.gif",
      "https://media.giphy.com/media/9Y5g3vK5Z5Z5Z/giphy.gif"
    ];

    const steps = [
      { text: `Hey Guddu 💌<br><br>Kabhi kabhi kuch feelings itni gehri hoti hain ki unhe words mein samajhana mushkil ho jata hai...<br><br>Tu wo insaan hai jo mere har din ko thoda zyada khubsurat bana deta hai.` },
      { text: `Guddu,<br><br>Jab bhi main thoda udaas hota hoon, tere ek message ya yaad mere chehre pe muskaan laa deti hai.<br><br>Tu mera safe place hai 💕` },
      { text: `Meri sabse favourite baat teri yeh hai ki tu hamesha sach bolta hai.<br><br>Tere saath main bilkul asli main ban sakta hoon.<br><br>I feel so lucky to have you 💕` },
      { text: `Guddu,<br><br>Tu jitna important hai mere liye, shayad main kabhi poora bol nahi paunga.<br><br>Ye chhota sa journey ek koshish hai ki tu samajh sake kitna special tu mere liye hai.` },
      { text: `Guddu 💕<br><br>Thank you for being my best friend.<br>Thank you for all the memories.<br>Thank you for simply being you.<br><br>Main yahan hoon, hamesha tere saath.<br><br>With all my heart,<br>Tera Bestie ❤️` }
    ];

    function startJourney() {
      document.getElementById("startPage").classList.add("hidden");
      document.getElementById("journeyPage").classList.remove("hidden");
      renderStep();
      setTimeout(() => {
        document.getElementById("song").play();
      }, 800);
    }

    function renderStep() {
      const container = document.getElementById("stepContainer");
      container.innerHTML = `
        <div class="text-center">
          <img src="${catGifs[currentStep-1]}" class="mx-auto mb-6 w-56 h-56 object-contain rounded-2xl shadow-md" alt="Cute Cat">
          <div class="text-box p-6 shadow-inner text-xl leading-relaxed text-gray-700">
            ${steps[currentStep-1].text}
          </div>
        </div>
      `;

      document.getElementById("currentStep").textContent = currentStep;
      document.getElementById("progressBar").style.width = (currentStep / totalSteps * 100) + "%";

      document.getElementById("prevBtn").style.display = currentStep === 1 ? "none" : "flex";
      document.getElementById("nextBtn").textContent = currentStep === totalSteps ? "End Journey 💕" : "Next →";
    }

    function nextStep() {
      if (currentStep < totalSteps) {
        currentStep++;
        renderStep();
      } else {
        alert("❤️ Journey complete! Thank you for being my bestie 💕");
      }
    }

    function prevStep() {
      if (currentStep > 1) {
        currentStep--;
        renderStep();
      }
    }

    function toggleMusic() {
      const audio = document.getElementById("song");
      const icon = document.getElementById("playIcon");
      if (audio.paused) {
        audio.play();
        icon.classList.replace("fa-play", "fa-pause");
      } else {
        audio.pause();
        icon.classList.replace("fa-pause", "fa-play");
      }
    }

    window.onload = () => {};
  </script>
</body>
</html>
